{
  "name": "@urtime/mcp-server",
  "version": "1.2.2",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "urtime-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/auth/pages && cp -r src/auth/pages/* dist/auth/pages/",
    "dev": "tsx watch src/server.ts",
    "dev:http": "MCP_HTTP_MODE=true tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:http": "MCP_HTTP_MODE=true node dist/server.js",
    "clean": "rm -rf dist",
    "inspect": "npx @modelcontextprotocol/inspector node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@urtime/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.0",
    "sql.js": "^1.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ]
}
