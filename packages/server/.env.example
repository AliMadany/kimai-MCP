# =============================================================================
# urTime MCP Server - Production Configuration
# =============================================================================
# Copy this file to .env and configure for your server
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Server Mode
# -----------------------------------------------------------------------------
MCP_MODE=http

# -----------------------------------------------------------------------------
# REQUIRED: Your Domain
# -----------------------------------------------------------------------------
# The public HTTPS URL where your server is accessible
# Example: https://mcp.yourdomain.com
HTTP_BASE_URL=https://mcp.yourdomain.com

# Port the server listens on (nginx/reverse proxy forwards to this)
HTTP_PORT=3002

# Host to bind to (0.0.0.0 for all interfaces)
HTTP_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# REQUIRED: Security
# -----------------------------------------------------------------------------
# Generate a secure encryption key:
#   openssl rand -hex 32
# This encrypts stored Kimai tokens
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# RECOMMENDED: CORS
# -----------------------------------------------------------------------------
# Restrict to specific origins in production
# Example: https://claude.ai,https://chat.openai.com
CORS_ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# OPTIONAL: Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# OPTIONAL: OAuth Token Lifetimes (seconds)
# -----------------------------------------------------------------------------
OAUTH_ACCESS_TOKEN_EXPIRY=3600
OAUTH_REFRESH_TOKEN_EXPIRY=2592000
OAUTH_AUTH_CODE_EXPIRY=600

# -----------------------------------------------------------------------------
# OPTIONAL: Database Path
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/auth.db

# -----------------------------------------------------------------------------
# OPTIONAL: Server Identity
# -----------------------------------------------------------------------------
MCP_SERVER_NAME=urtime-kimai
MCP_SERVER_VERSION=1.0.0

# -----------------------------------------------------------------------------
# OPTIONAL: Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_REQUESTS=true
